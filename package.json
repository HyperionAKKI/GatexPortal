{
  "name": "gatex-registration-portal",
  "version": "1.0.0",
  "description": "GateX AI Data Collection & Registration Portal",
  "main": "server/index.js",
  "scripts": {
    "dev": "nodemon server/index.js",
    "dev:client": "serve public -l 3000",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "start": "node server/index.js",
    "start:prod": "node server/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "check": "npx prisma validate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@prisma/client": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "fuse.js": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "prisma": "^5.0.0",
    "serve": "^14.2.5"
  }
}
